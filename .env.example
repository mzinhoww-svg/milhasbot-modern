# Banco de dados (Supabase / Postgres) — OPCIONAL.
# Sem esta variável, o app funciona normalmente com os dados estáticos de lib/data/.
# Com ela, as leituras no servidor passam a vir do banco.
#
# No Supabase: Project Settings → Database → Connection string (URI).
# Use a connection string "pooler" (porta 6543) para serverless na Vercel.
DATABASE_URL="postgresql://postgres:[SENHA]@[HOST]:6543/postgres?pgbouncer=true"

# Admin (/admin protegido por Basic Auth). Defina nas variáveis da Vercel.
ADMIN_USER="admin"
ADMIN_PASSWORD="troque-esta-senha"
