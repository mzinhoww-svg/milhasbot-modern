// Schema do MilhasBot Modern
// Espelha as estruturas de lib/data/ (fonte estática de fallback).
// learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Programa {
  id            String   @id @default(cuid())
  slug          String   @unique
  nome          String
  tipo          String // "Companhia aérea" | "Banco de pontos"
  valorRefBaixo Float
  valorRefAlto  Float
  validadeMeses Int? // null = não expira
  temClube      Boolean  @default(false)
  paridades     String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  passagens Passagem[]
}

model Passagem {
  id         String   @id @default(cuid())
  destino    String
  origem     String
  programaId String
  programa   Programa @relation(fields: [programaId], references: [id])
  milhas     Int
  cabine     String // economica | executiva
  regiao     String
  createdAt  DateTime @default(now())

  @@index([destino, milhas])
}

model BonusTransferencia {
  id         String   @id @default(cuid())
  origem     String
  destino    String
  percentual Float
  inicio     DateTime
  fim        DateTime
  ativo      Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([origem, destino])
}
